{
  "name": "ludix_launcher",
  "version": "1.0.0",
  "description": "Ludix Launcher",
  "author": "Ludix",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.gaudiestbaker74.ludix_launcher",
    "productName": "Ludix Launcher",
    "asar": true,
    "publish": [
      {
        "provider": "github"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "files": [
      "**/*",
      "!dist",
      "!.github",
      "!package-lock.json"
    ]
  },
  "dependencies": {
    "winreg": "^1.2.5"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^26.0.12"
  }
}
